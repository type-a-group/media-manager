{
	"name": "media-manager",
	"private": false,
	"version": "0.0.1",
	"type": "module",
	"bin": {
		"media-manager": "bin/media-manager.js"
	},
	"exports": {
		".": null,
		"./reader": {
			"types": "./dist/reader/index.d.ts",
			"import": "./dist/reader/index.js"
		},
		"./reader/vite": {
			"types": "./dist/reader/vite.d.ts",
			"import": "./dist/reader/vite.js"
		}
	},
	"files": [
		"build",
		"bin",
		"dist",
		"README.md",
		"package.json"
	],
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"build:reader": "tsc -p tsconfig.reader.json",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"start": "node build",
		"prepublishOnly": "npm run build && npm run build:reader",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"lint:prettier": "prettier --check .",
		"lint:eslint": "eslint .",
		"lint": "npm run lint:prettier && npm run lint:eslint",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:serve": "node scripts/serve-test.mjs",
		"upgrade-data": "node scripts/upgrade-data.mjs"
	},
	"devDependencies": {
		"@internationalized/date": "^3.12.2",
		"@lucide/svelte": "^1.21.0",
		"@sveltejs/adapter-node": "^5.5.2",
		"@sveltejs/kit": "^2.16.0",
		"@sveltejs/vite-plugin-svelte": "^5.0.0",
		"@tailwindcss/forms": "^0.5.9",
		"@tailwindcss/typography": "^0.5.15",
		"@tailwindcss/vite": "^4.0.0",
		"@types/heic-convert": "^2.1.0",
		"@types/node": "^24.0.10",
		"@typescript-eslint/eslint-plugin": "^8.54.0",
		"@typescript-eslint/parser": "^8.54.0",
		"bits-ui": "^2.18.1",
		"clsx": "^2.1.1",
		"eslint": "^9.39.2",
		"eslint-plugin-svelte": "^3.14.0",
		"formsnap": "^2.0.1",
		"playwright": "^1.60.0",
		"prettier": "^3.4.2",
		"prettier-plugin-svelte": "^3.3.3",
		"svelte": "^5.0.0",
		"svelte-check": "^4.0.0",
		"svelte-eslint-parser": "^1.4.1",
		"svelte-sonner": "^1.0.5",
		"sveltekit-superforms": "^2.27.1",
		"tailwind-merge": "^3.3.1",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.0.0",
		"tw-animate-css": "^1.3.5",
		"typescript": "^5.0.0",
		"vite": "^6.2.6",
		"vitest": "^4.0.18"
	},
	"dependencies": {
		"exiftool-vendored": "^25.0.0",
		"heic-convert": "^2.1.0",
		"lucide-svelte": "^0.525.0",
		"mode-watcher": "^1.1.0",
		"sharp": "^0.34.2"
	}
}
